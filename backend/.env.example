# ── Database ─────────────────────────────────────────────────────────
# Replace CHANGE_ME with your real local PostgreSQL password.
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME@localhost:5432/it_school_db

# ── Auth / JWT ───────────────────────────────────────────────────────
# Generate a long random string, e.g.: python -c "import secrets;print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Telegram bot (optional) ──────────────────────────────────────────
# Bot is OFF by default. To enable: ENABLE_BOT=true and set a valid token.
ENABLE_BOT=false
BOT_MODE=disabled
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# ── AI assistant (optional) ──────────────────────────────────────────
GEMINI_API_KEY=

# ── Operational toggles ──────────────────────────────────────────────
# echo SQL to console (dev only)
SQL_ECHO=false
# auto-create tables on startup (dev convenience; use Alembic in prod)
AUTO_CREATE_DB=true
# allowed CORS origins: "*" for dev, comma-separated domains in production
CORS_ORIGINS=*
